{
	"name": "cognipedia",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.30.1",
	"volta": {
		"node": "24.13.1",
		"pnpm": "10.30.1"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "astro check && svelte-check",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"changeset": "changeset",
		"db:reset": "rm -rf .wrangler/state/v3/d1 && wrangler d1 execute cognipedia-db --local --file=schema.sql",
		"test:links": "vitest run src/content/__tests__/bias-links.test.ts --config vitest.links.config.ts"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^13.1.3",
		"@astrojs/svelte": "^8.0.3",
		"@levita-js/svelte": "^0.3.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"astro": "^6.0.8",
		"clsx": "^2.1.1",
		"svelte": "^5.53.2",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"zod": "^3.25.76"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"workerd"
		]
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@biomejs/biome": "^2.4.4",
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"@cloudflare/workers-types": "^4.20260317.1",
		"@iconify-json/lucide": "^1.2.98",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte-check": "^4.4.3",
		"typescript": "^5.9.3",
		"unplugin-icons": "^23.0.1",
		"vitest": "^4.1.1",
		"wrangler": "^4.77.0"
	}
}
