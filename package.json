{
	"name": "cognipedia",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.30.1",
	"volta": {
		"node": "24.13.1",
		"pnpm": "10.30.1"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "astro check && svelte-check",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"changeset": "changeset",
