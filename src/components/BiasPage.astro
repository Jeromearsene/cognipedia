---
import type { CollectionEntry } from "astro:content";
/**
 * Full bias page layout: header with metadata badges, styled markdown content,
 * interactive situation/quiz, sources, and related biases.
 */
import { render } from "astro:content";
import BiasRelatedSection from "@/components/BiasRelatedSection.astro";
import BiasSourcesSection from "@/components/BiasSourcesSection.astro";
import BiasInteractive from "@/components/interactive/BiasInteractive.svelte";
import type { Locale } from "@/i18n/i18n";
import { t } from "@/i18n/i18n";
import { DIFFICULTY_COLORS } from "@/lib/constants";
import { getBiasInteractiveLabels } from "@/lib/labels";

interface Props {
	entry: CollectionEntry<"biases">;
	locale: Locale;
}

const { entry, locale } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const showOriginalName = data.originalName !== data.title;
---

<article class="mx-auto max-w-3xl">
  <!-- Header: title, original name, badges -->
  <header class="mb-8">
    <h1 class="text-3xl font-bold">{data.title}</h1>
    {showOriginalName && (
      <p class="mt-1 text-lg italic text-text-secondary">{data.originalName}</p>
    )}
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <span
        class="rounded-full px-2.5 py-0.5 text-xs font-medium text-white"
        style={`background-color: var(--family-${data.family})`}
      >
        {t(locale, `bias.family.${data.family}`)}
      </span>
      <span class={`rounded-full px-2.5 py-0.5 text-xs font-medium ${DIFFICULTY_COLORS[data.difficulty]}`}>
        {t(locale, `bias.difficulty.${data.difficulty}`)}
      </span>
      {data.tags.map((tag) => (
        <span class="rounded-full border border-border px-2.5 py-0.5 text-xs text-text-secondary">
          {tag}
        </span>
      ))}
    </div>
  </header>

  <!-- Markdown content with typography styles -->
  <div class="prose prose-slate max-w-none">
    <Content />
  </div>

  <!-- Interactive section: situation + quiz orchestrator -->
  <BiasInteractive
    biasSlug={data.slug}
    profileUrl={`/${locale}/${t(locale, "slug.profile")}`}
    situation={data.situation}
    quiz={data.quiz}
    labels={getBiasInteractiveLabels(locale)}
    client:visible
  />

  <!-- Sources -->
  <BiasSourcesSection
    locale={locale}
    wikipedia={data.sources.wikipedia}
    papers={data.sources.papers}
    videos={data.sources.videos}
  />

  <!-- Related biases -->
  <BiasRelatedSection locale={locale} relatedBiases={data.relatedBiases} />
</article>
