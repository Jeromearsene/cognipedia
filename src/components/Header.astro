---
import type { Locale } from "@/i18n/i18n";
import { SUPPORTED_LOCALES, t } from "@/i18n/i18n";

const { locale, currentPath, altLangHrefs } = Astro.locals;

const navLinks = [
	{ key: "nav.home", href: `/${locale}/` },
	{ key: "nav.leaderboard", href: `/${locale}/${t(locale, "slug.leaderboard")}` },
	{ key: "nav.about", href: `/${locale}/${t(locale, "slug.about")}` },
	{ key: "nav.profile", href: `/${locale}/${t(locale, "slug.profile")}` },
];

/**
 * Builds the URL for switching to another locale.
 * Uses `altLangHrefs` when available (content pages with localized slugs),
 * otherwise swaps the locale prefix in the current path.
 */
const switchLangPath = (target: Locale) => {
	if (altLangHrefs?.[target]) return altLangHrefs[target];
	const segments = currentPath.split("/").filter(Boolean);
	segments[0] = target;
	const path = `/${segments.join("/")}`;
	return currentPath.endsWith("/") ? `${path}/` : path;
};
---

<header class="border-b border-border bg-surface">
  <nav class="mx-auto flex w-full max-w-6xl items-center justify-between px-8 py-4">
    <a href={`/${locale}/`} class="text-xl font-bold text-text no-underline hover:no-underline">
      Cognipedia
    </a>

    <ul class="flex gap-6 list-none m-0 p-0">
      {navLinks.map(({ key, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              "no-underline hover:underline",
              currentPath === href ? "font-bold text-accent" : "text-text-secondary",
            ]}
          >
            {t(locale, key)}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex gap-2 text-sm">
      {SUPPORTED_LOCALES.map((lang) => (
        <a
          href={switchLangPath(lang)}
          class:list={[
            "no-underline uppercase",
            lang === locale ? "font-bold text-accent" : "text-text-secondary hover:underline",
          ]}
        >
          {lang}
        </a>
      ))}
    </div>
  </nav>
</header>
