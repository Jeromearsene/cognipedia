---
/**
 * Displays bias sources: Wikipedia link, scientific papers, and videos.
 * Only renders sections that have data.
 */
import { Icon } from "astro-icon/components";
import type { Locale } from "@/i18n/i18n";
import { t } from "@/i18n/i18n";

interface Paper {
	title: string;
	url: string;
}

interface Video {
	title: string;
	url: string;
	lang: string;
}

interface Props {
	locale: Locale;
	wikipedia: string;
	papers?: Paper[];
	videos?: Video[];
}

const { locale, wikipedia, papers, videos } = Astro.props;
---

<section class="mt-12 rounded-xl border border-border bg-surface p-6">
  <h2 class="mb-4 text-lg font-bold">{t(locale, "sources.title")}</h2>

  <div class="space-y-4">
    <div class="flex items-center gap-2">
      <Icon name="lucide:book-open" class="h-4 w-4 text-text-secondary" />
      <a href={wikipedia} target="_blank" rel="noopener noreferrer">
        {t(locale, "sources.wikipedia")}
      </a>
    </div>

    {papers && papers.length > 0 && (
      <div>
        <h3 class="mb-2 flex items-center gap-2 text-sm font-medium text-text-secondary">
          <Icon name="lucide:file-text" class="h-4 w-4" />
          {t(locale, "sources.papers")}
        </h3>
        <ul class="list-none space-y-1 pl-6">
          {papers.map((paper) => (
            <li>
              <a href={paper.url} target="_blank" rel="noopener noreferrer" class="text-sm">
                {paper.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {videos && videos.length > 0 && (
      <div>
        <h3 class="mb-2 flex items-center gap-2 text-sm font-medium text-text-secondary">
          <Icon name="lucide:play-circle" class="h-4 w-4" />
          {t(locale, "sources.videos")}
        </h3>
        <ul class="list-none space-y-1 pl-6">
          {videos.map((video) => (
            <li class="flex items-center gap-2">
              <a href={video.url} target="_blank" rel="noopener noreferrer" class="text-sm">
                {video.title}
              </a>
              <span class="rounded bg-border px-1.5 py-0.5 text-xs uppercase text-text-secondary">
                {video.lang}
              </span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>
