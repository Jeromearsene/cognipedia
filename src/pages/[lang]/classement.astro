---
/**
 * Leaderboard page (French route: /fr/classement).
 * Redirects English users to /en/leaderboard.
 */
import Leaderboard from "@/components/Leaderboard.svelte";
import { t, validateLocaleParam } from "@/i18n/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";

const { lang } = Astro.params;
const result = validateLocaleParam(lang, Astro.request.headers.get("accept-language"));
if (!result.locale) return Astro.redirect(result.redirectTo);
const locale = result.locale;

if (locale === "en") {
	return Astro.redirect("/en/leaderboard");
}

Astro.locals.altLangHrefs = { en: "/en/leaderboard" };

const pageTitle = t(locale, "leaderboard.title");
const labels = {
	title: pageTitle,
	rank: t(locale, "leaderboard.rank"),
	pseudo: t(locale, "leaderboard.pseudo"),
	score: t(locale, "leaderboard.score"),
	loading: t(locale, "leaderboard.loading"),
	empty: t(locale, "leaderboard.empty"),
	error: t(locale, "leaderboard.error"),
};
---

<BaseLayout title={`${pageTitle} — ${t(locale, "site.title")}`} lang={locale}>
	<h1 class="mb-8 text-3xl font-bold">{pageTitle}</h1>
	<Leaderboard labels={labels} client:visible />
</BaseLayout>
