---
import { getCollection } from "astro:content";
import Quiz from "@/components/interactive/Quiz.svelte";
import Situation from "@/components/interactive/Situation.svelte";
import type { Locale } from "@/i18n/i18n";
import { isLocale, t } from "@/i18n/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { parseQuiz, parseSituation } from "@/lib/parse-bias-content";

const { lang, slug } = Astro.params;

if (!lang || !isLocale(lang)) {
	return Astro.redirect("/fr/");
}

const locale = lang as Locale;

const allBiases = await getCollection("biases");
const biases = allBiases.filter((entry) => entry.id.endsWith(`/${locale}`));
const entry = biases.find((e) => e.data.slug === slug);

if (!entry) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const { Content } = await entry.render();
const rawBody = entry.body ?? "";
const situation = parseSituation(rawBody);
const quiz = parseQuiz(rawBody);

const title = `${entry.data.title} — ${t(locale, "site.title")}`;

const quizLabels = {
	next: t(locale, "quiz.next"),
	results: t(locale, "quiz.results"),
	correct: t(locale, "quiz.correct"),
	incorrect: t(locale, "quiz.incorrect"),
};
---

<BaseLayout title={title} lang={locale}>
	<article>
		<h1>{entry.data.title}</h1>
		<Content />
		{situation && <Situation data={situation} client:visible />}
		{quiz && <Quiz data={quiz} labels={quizLabels} client:visible />}
	</article>
</BaseLayout>
