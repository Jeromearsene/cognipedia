---
import { getCollection, render } from "astro:content";
import Quiz from "@/components/interactive/Quiz.svelte";
import Situation from "@/components/interactive/Situation.svelte";
import type { Locale } from "@/i18n/i18n";
import { isLocale, SUPPORTED_LOCALES, t } from "@/i18n/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";

/**
 * Dynamic bias page — renders a single cognitive bias entry.
 * URL pattern: /:lang/:slug (e.g. /fr/biais-ancrage, /en/anchoring-bias).
 * Also computes alternate-language URLs so the Header language switcher
 * can link to the same bias in another locale.
 */

const { lang, slug } = Astro.params;

if (!lang || !isLocale(lang)) {
	return Astro.redirect("/fr/");
}

// Safe after isLocale() guard above
const locale: Locale = lang;

// Fetch all biases, then filter to current locale and find by slug
const allBiases = await getCollection("biases");
const biases = allBiases.filter((bias) => bias.filePath?.endsWith(`${locale}.md`));
const entry = biases.find((bias) => bias.data.slug === slug);

if (!entry) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const { Content } = await render(entry);
const { situation, quiz } = entry.data;

/**
 * Build alternate-language URLs for the Header language switcher.
 * Derives the bias folder from the current entry's filePath (e.g. "anchoring-bias/fr.md"
 * → "anchoring-bias"), then finds the same bias in other locales.
 */
const biasFolder = entry.filePath?.replace(`/${locale}.md`, "").split("/").pop() ?? "";
Astro.locals.altLangHrefs = Object.fromEntries(
	SUPPORTED_LOCALES.filter((otherLocale) => otherLocale !== locale)
		.map((otherLocale) => {
			const alternate = allBiases.find((bias) =>
				bias.filePath?.endsWith(`${biasFolder}/${otherLocale}.md`),
			);
			return alternate ? [otherLocale, `/${otherLocale}/${alternate.data.slug}`] : [];
		})
		.filter((pair) => pair.length > 0),
);

const title = `${entry.data.title} — ${t(locale, "site.title")}`;

/** Translated labels passed to the Quiz Svelte component. */
const quizLabels = {
	next: t(locale, "quiz.next"),
	results: t(locale, "quiz.results"),
	correct: t(locale, "quiz.correct"),
	incorrect: t(locale, "quiz.incorrect"),
};
---

<BaseLayout title={title} lang={locale}>
	<article>
		<h1>{entry.data.title}</h1>
		<Content />
		{situation && <Situation data={situation} client:visible />}
		{quiz && <Quiz data={quiz} labels={quizLabels} client:visible />}
	</article>
</BaseLayout>
