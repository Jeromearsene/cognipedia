---
/**
 * Leaderboard page (English route: /en/leaderboard).
 * Redirects French users to /fr/classement.
 */
import Leaderboard from "@/components/Leaderboard.svelte";
import type { Locale } from "@/i18n/i18n";
import { getLocaleFromAcceptLanguage, isLocale, t } from "@/i18n/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";

const { lang } = Astro.params;

if (!lang || !isLocale(lang)) {
	const fallback = getLocaleFromAcceptLanguage(Astro.request.headers.get("accept-language"));
	return Astro.redirect(`/${fallback}/`);
}

const locale: Locale = lang;

if (locale === "fr") {
	return Astro.redirect("/fr/classement");
}

Astro.locals.altLangHrefs = { fr: "/fr/classement" };

const pageTitle = t(locale, "leaderboard.title");
const labels = {
	title: pageTitle,
	rank: t(locale, "leaderboard.rank"),
	pseudo: t(locale, "leaderboard.pseudo"),
	score: t(locale, "leaderboard.score"),
	loading: t(locale, "leaderboard.loading"),
	empty: t(locale, "leaderboard.empty"),
};
---

<BaseLayout title={`${pageTitle} — ${t(locale, "site.title")}`} lang={locale}>
	<h1 class="mb-8 text-3xl font-bold">{pageTitle}</h1>
	<Leaderboard labels={labels} client:visible />
</BaseLayout>
