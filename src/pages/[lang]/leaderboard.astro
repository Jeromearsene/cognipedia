---
/** Leaderboard page (English route: /en/leaderboard). */
import LeaderboardComponent from "@/components/Leaderboard.svelte";
import { t } from "@/i18n/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";

const { locale } = Astro.locals;

Astro.locals.altLangHrefs = { fr: "/fr/classement" };

const pageTitle = t(locale, "leaderboard.title");
const labels = {
	title: pageTitle,
	rank: t(locale, "leaderboard.rank"),
	pseudo: t(locale, "leaderboard.pseudo"),
	score: t(locale, "leaderboard.score"),
	loading: t(locale, "leaderboard.loading"),
	empty: t(locale, "leaderboard.empty"),
	error: t(locale, "leaderboard.error"),
};
---

<BaseLayout title={`${pageTitle} — ${t(locale, "site.title")}`} description={t(locale, "site.description")} lang={locale}>
	<h1 class="mb-8 text-3xl font-bold">{pageTitle}</h1>
	<LeaderboardComponent labels={labels} client:visible />
</BaseLayout>
