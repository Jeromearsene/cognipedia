---
/** Leaderboard page (English route: /en/leaderboard). */
import LeaderboardComponent from "@/components/Leaderboard.svelte";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { m } from "@/paraglide/messages";

const { locale } = Astro.locals;

Astro.locals.altLangHrefs = { fr: "/fr/classement" };

const pageTitle = m.leaderboard_title();
const labels = {
	title: pageTitle,
	rank: m.leaderboard_rank(),
	pseudo: m.leaderboard_pseudo(),
	score: m.leaderboard_score(),
	loading: m.leaderboard_loading(),
	empty: m.leaderboard_empty(),
	error: m.leaderboard_error(),
};
---

<BaseLayout title={`${pageTitle} — ${m.site_title()}`} description={m.site_description()} lang={locale}>
	<h1 class="mb-8 text-3xl font-bold">{pageTitle}</h1>
	<LeaderboardComponent labels={labels} client:visible />
</BaseLayout>
