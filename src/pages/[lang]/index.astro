---
/**
 * Homepage — hero section + dual-view bias catalogue.
 * Default view: grouped by cognitive bias family.
 * Flat view: filterable grid (Svelte island).
 */
import BiasCard from "@/components/BiasCard.svelte";
import BiasGrid from "@/components/BiasGrid.svelte";
import { t } from "@/i18n/i18n";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBiasesForLocale } from "@/lib/biases";
import { DIFFICULTIES, FAMILIES } from "@/lib/constants";

const { locale } = Astro.locals;
const { localized: biases } = await getBiasesForLocale(locale);

/** Serialize a bias entry into the shape BiasCard/BiasGrid expects. */
const toBiasItem = (entry: (typeof biases)[number]) => ({
	href: `/${locale}/${t(locale, "slug.bias")}/${entry.data.slug}`,
	title: entry.data.title,
	family: entry.data.family,
	familyLabel: t(locale, `bias.family.${entry.data.family}`),
	difficulty: entry.data.difficulty,
	difficultyLabel: t(locale, `bias.difficulty.${entry.data.difficulty}`),
});

const biasItems = biases.map(toBiasItem);

/** Biases grouped by family, preserving FAMILIES order. */
const groupedByFamily = FAMILIES.map((family) => ({
	key: family,
	label: t(locale, `bias.family.${family}`),
	biases: biasItems.filter((bias) => bias.family === family),
}));

const familyOptions = FAMILIES.map((family) => ({
	key: family,
	label: t(locale, `bias.family.${family}`),
}));
const difficultyOptions = DIFFICULTIES.map((difficulty) => ({
	key: difficulty,
	label: t(locale, `bias.difficulty.${difficulty}`),
}));

const title = t(locale, "site.title");
const description = t(locale, "site.description");

/** Detect filter query params to render the correct initial view (SSR, no flash). */
const filterFamily = Astro.url.searchParams.get("family");
const filterDifficulty = Astro.url.searchParams.get("difficulty");
const hasFilters = filterFamily !== null || filterDifficulty !== null;
---

<BaseLayout title={title} description={description} lang={locale}>
  <!-- Hero -->
  <section class="flex flex-col items-center gap-4 py-16 text-center">
    <h1 class="text-5xl font-bold">{title}</h1>
    <p class="max-w-lg text-lg text-text-secondary">{description}</p>
  </section>

  <!-- Catalogue -->
  <section id="catalogue" class="scroll-mt-8">
    <!-- View toggle tabs -->
    <div class="mb-8 flex gap-4 border-b border-border" id="view-tabs">
      <button
        class={`border-b-2 px-4 py-2 text-sm font-medium ${hasFilters ? "border-transparent text-text-secondary hover:text-text" : "border-accent text-accent"}`}
        data-view="grouped"
      >
        {t(locale, "home.view.grouped")}
      </button>
      <button
        class={`border-b-2 px-4 py-2 text-sm font-medium ${hasFilters ? "border-accent text-accent" : "border-transparent text-text-secondary hover:text-text"}`}
        data-view="flat"
      >
        {t(locale, "home.view.flat")}
      </button>
    </div>

    <!-- Grouped view (hidden when filters are active) -->
    <div id="view-grouped" class={hasFilters ? "hidden" : ""}>
      {groupedByFamily.map(({ key, label, biases: familyBiases }) => (
        <div class="mb-10">
          <h2
            class="mb-4 border-l-4 pl-3 text-xl font-bold"
            style={`border-color: var(--family-${key})`}
          >
            {label}
          </h2>
          {familyBiases.length > 0 ? (
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {familyBiases.map((bias) => (
                <BiasCard {...bias} client:visible />
              ))}
            </div>
          ) : (
            <p class="py-6 text-center text-text-secondary">
              {t(locale, "home.empty")}
            </p>
          )}
        </div>
      ))}
    </div>

    <!-- Flat view (Svelte island, hidden by default) -->
    <div id="view-flat" class={hasFilters ? "" : "hidden"}>
      <BiasGrid
        biases={biasItems}
        families={familyOptions}
        difficulties={difficultyOptions}
        initialFamily={filterFamily}
        initialDifficulty={filterDifficulty}
        labels={{
          family: t(locale, "home.filter.family"),
          difficulty: t(locale, "home.filter.difficulty"),
          noResults: t(locale, "home.no-results"),
        }}
        client:visible
      />
    </div>
  </section>

  <!-- View toggle script (minimal inline JS for tab switching) -->
  <script is:inline>
    const switchView = (view) => {
      const grouped = document.getElementById("view-grouped");
      const flat = document.getElementById("view-flat");
      const buttons = document.querySelectorAll("[data-view]");

      grouped?.classList.toggle("hidden", view !== "grouped");
      flat?.classList.toggle("hidden", view !== "flat");

      buttons.forEach((btn) => {
        const isActive = btn.dataset.view === view;
        btn.classList.toggle("border-accent", isActive);
        btn.classList.toggle("text-accent", isActive);
        btn.classList.toggle("border-transparent", !isActive);
        btn.classList.toggle("text-text-secondary", !isActive);
      });
    };

    document.getElementById("view-tabs")?.addEventListener("click", (event) => {
      const button = event.target.closest("[data-view]");
      if (!button) return;
      switchView(button.dataset.view);
    });
  </script>
</BaseLayout>
